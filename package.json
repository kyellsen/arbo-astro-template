{
	"name": "arbo-astro-template",
	"type": "module",
	"version": "0.0.1",
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"lint": "eslint .",
		"lint:fix": "eslint . --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"prepare": "husky"
	},
	"lint-staged": {
		"*.{astro,js,mjs,ts}": [
			"eslint --fix",
			"prettier --write"
		],
		"*.{css,md,json}": [
			"prettier --write"
		]
	},
	"dependencies": {
		"@astrojs/sitemap": "^3.7.0",
		"@fontsource-variable/geist": "^5.2.8",
		"@fontsource-variable/geist-mono": "^5.2.7",
		"@tailwindcss/vite": "^4.2.1",
		"astro": "^5.17.1",
		"daisyui": "5.5.1-beta.2",
		"sharp": "^0.34.5",
		"tailwindcss": "^4.2.1"
	},
	"devDependencies": {
		"@typescript-eslint/parser": "^8.56.1",
		"eslint": "^10.0.2",
		"eslint-plugin-astro": "^1.6.0",
		"husky": "^9.1.7",
		"lint-staged": "^16.3.1",
		"prettier": "^3.8.1",
		"prettier-plugin-astro": "^0.14.1"
	}
}
