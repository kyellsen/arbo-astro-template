---
// src/components/sections/ContactSection.astro — Kontakt (reusable)
// Formular wurde entfernt: Zeigt nun Kontaktwege übersichtlich analog zum Footer an.
// Alle Kontaktdaten stammen aus site.config.ts (Single Source of Truth).
import { siteConfig } from "../../site.config";
import SectionHeader from "../SectionHeader.astro";
import Icon from "../Icon.astro";

const { company, contact, hours } = siteConfig;
const addr = company.address;
---

<section id="kontakt" class="max-w-6xl mx-auto px-6 py-24 reveal-on-scroll">
	<SectionHeader
		headline="Sprechen Sie uns an"
		description="Haben Sie Fragen zu unseren Leistungen oder möchten Sie ein Projekt besprechen? Wir freuen uns auf Ihre Nachricht."
		align="responsive"
	/>

	<div class="grid md:grid-cols-3 gap-8">
		<!-- Direkter Kontakt (Email, Telefon, Messenger) -->
		<div
			class="apple-glass rounded-2xl p-8 flex flex-col items-center md:items-start text-center md:text-left group hover:border-primary/30 transition-colors"
		>
			<div
				class="w-12 h-12 rounded-full bg-primary/10 flex items-center justify-center text-primary mb-6"
			>
				<Icon name="email" class="w-6 h-6" />
			</div>
			<h3 class="text-xl mb-4">Schreiben oder Anrufen</h3>
			<div class="space-y-4 text-base w-full">
				<a
					href={`mailto:${contact.email}`}
					class="flex items-center gap-3 hover:text-primary transition-colors justify-center md:justify-start"
				>
					<span class="font-mono break-all text-lg">{contact.email}</span>
				</a>
				<a
					href={`tel:${contact.phone}`}
					class="flex items-center gap-3 hover:text-primary transition-colors justify-center md:justify-start"
				>
					<span class="font-mono text-lg">{contact.phoneDisplay}</span>
				</a>
				<div class="pt-4 border-t border-base-300 w-full flex flex-col gap-3">
					<a
						href={contact.whatsapp}
						target="_blank"
						rel="noopener"
						class="flex items-center gap-2 hover:text-[#25D366] transition-colors justify-center md:justify-start"
					>
						<Icon name="whatsapp" class="w-5 h-5 shrink-0 text-[#25D366]" />
						<span>WhatsApp</span>
					</a>
					<a
						href={contact.signal}
						target="_blank"
						rel="noopener"
						class="flex items-center gap-2 hover:text-[#3A76F0] transition-colors justify-center md:justify-start"
					>
						<Icon name="signal" class="w-5 h-5 shrink-0 text-[#3A76F0]" />
						<span>Signal</span>
					</a>
				</div>
			</div>
		</div>

		<!-- Postanschrift -->
		<div
			class="apple-glass rounded-2xl p-8 flex flex-col items-center md:items-start text-center md:text-left group hover:border-secondary/30 transition-colors"
		>
			<div
				class="w-12 h-12 rounded-full bg-secondary/10 flex items-center justify-center text-secondary mb-6"
			>
				<svg
					class="w-6 h-6"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
					aria-hidden="true"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M3 19v-8.93a2 2 0 01.89-1.664l7-4.666a2 2 0 012.22 0l7 4.666A2 2 0 0121 10.07V19M3 19a2 2 0 002 2h14a2 2 0 002-2M3 19l6.75-4.5M21 19l-6.75-4.5M3 10l6.75 4.5M21 10l-6.75 4.5"
					></path>
				</svg>
			</div>
			<h3 class="text-xl mb-4">Postanschrift</h3>
			<div class="space-y-2 text-base text-base-content/70">
				<p class="font-medium text-base-content">{company.name}</p>
				<p>{addr.street}</p>
				<p>{addr.zip} {addr.city}</p>
				<p class="pt-2">{addr.region}</p>
			</div>
			<div class="mt-6 w-full pt-4 border-t border-base-300">
				<div
					class="rounded-xl bg-base-100/40 p-3 text-sm text-base-content/70 text-center md:text-left"
				>
					Nur Briefkasten &amp; Büro.<br />Wir sind meistens für unsere Kunden im Gelände.
				</div>
			</div>
		</div>

		<!-- Erreichbarkeit / Öffnungszeiten -->
		<div
			class="apple-glass rounded-2xl p-8 flex flex-col items-center md:items-start text-center md:text-left group hover:border-accent/30 transition-colors"
		>
			<div
				class="w-12 h-12 rounded-full bg-accent/10 flex items-center justify-center text-accent mb-6"
			>
				<Icon name="clock" class="w-6 h-6" />
			</div>
			<h3 class="text-xl mb-4">Erreichbarkeit</h3>
			<div class="space-y-3 w-full text-base">
				{
					hours.map((h) => (
						<div class="flex justify-between items-center pb-2 border-b border-base-300 last:border-0 last:pb-0">
							<span class="text-base-content/70 font-medium">{h.days}</span>
							<span class="font-mono">{h.time}</span>
						</div>
					))
				}
			</div>
			<div
				class="mt-6 p-4 rounded-xl bg-accent/5 border border-accent/10 w-full text-sm text-center md:text-left text-base-content/80"
			>
				<p>Termine nach vorheriger Vereinbarung.</p>
			</div>
		</div>
	</div>
</section>
