---
// src/components/sections/ContactSection.astro — Kontakt (reusable)
// Alle Kontaktdaten stammen aus site.config.ts (Single Source of Truth).
import heroImage from "../../assets/heroes/contact-hero.png";
import { siteConfig } from "../../site.config";

// Hero image exported for use in parallax start page
export const sectionMeta = {
	heroImage,
	heroAlt: "Einladender Weg unter alten Eichen in der Holsteinischen Schweiz",
};

const { company, contact, hours } = siteConfig;
const addr = company.address;
---

<section id="kontakt" class="max-w-6xl mx-auto px-6 py-24 animate-fade-in">
	<div class="mb-12">
		<span
			class="inline-block px-4 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-mono font-bold tracking-widest uppercase mb-4"
		>
			Kontakt aufnehmen
		</span>
		<h2>Sprechen Sie uns an</h2>
		<p class="text-base-content/70 mt-4 max-w-2xl">
			Haben Sie Fragen zu unseren Leistungen oder möchten Sie ein Angebot? Wir freuen uns auf Ihre
			Nachricht.
		</p>
	</div>

	<div class="grid md:grid-cols-2 gap-12">
		<!-- Kontaktformular -->
		<div class="bg-base-200 rounded-2xl p-8 border border-base-300">
			<h3 class="text-xl mb-6">Nachricht senden</h3>
			<form class="space-y-5">
				<div>
					<label for="contact-name" class="block text-sm font-medium mb-1">Name</label>
					<input
						id="contact-name"
						type="text"
						placeholder="Ihr Name"
						class="input input-bordered w-full"
					/>
				</div>
				<div>
					<label for="contact-email" class="block text-sm font-medium mb-1">E-Mail</label>
					<input
						id="contact-email"
						type="email"
						placeholder="ihre@email.de"
						class="input input-bordered w-full"
					/>
				</div>
				<div>
					<label for="contact-phone" class="block text-sm font-medium mb-1"
						>Telefon <span class="text-base-content/40">(optional)</span></label
					>
					<input
						id="contact-phone"
						type="tel"
						placeholder="+49 ..."
						class="input input-bordered w-full"
					/>
				</div>
				<div>
					<label for="contact-message" class="block text-sm font-medium mb-1">Nachricht</label>
					<textarea
						id="contact-message"
						placeholder="Beschreiben Sie Ihr Anliegen..."
						class="textarea textarea-bordered w-full"
						rows="5"></textarea>
				</div>
				<button type="submit" class="btn btn-primary w-full rounded-xl shadow-md">
					Nachricht absenden
				</button>
			</form>
		</div>

		<!-- Kontaktdaten -->
		<div class="space-y-8">
			<div class="bg-base-200 rounded-2xl p-8 border border-base-300">
				<h3 class="mb-4">Kontaktdaten</h3>
				<div class="space-y-4 text-sm">
					<div class="flex items-start gap-3">
						<svg
							class="w-5 h-5 text-primary shrink-0 mt-0.5"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
							><path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
							></path><path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg
						>
						<div>
							<p class="font-medium">Adresse</p>
							<p class="text-base-content/60">{addr.zip} {addr.city}</p>
							<p class="text-base-content/60">{addr.region}</p>
						</div>
					</div>
					<div class="flex items-start gap-3">
						<svg
							class="w-5 h-5 text-primary shrink-0 mt-0.5"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
							><path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
							></path></svg
						>
						<div>
							<p class="font-medium">E-Mail</p>
							<p class="text-base-content/60 font-mono">{contact.email}</p>
						</div>
					</div>
					<div class="flex items-start gap-3">
						<svg
							class="w-5 h-5 text-primary shrink-0 mt-0.5"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
							><path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
							></path></svg
						>
						<div>
							<p class="font-medium">Telefon</p>
							<p class="text-base-content/60 font-mono">{contact.phoneDisplay}</p>
						</div>
					</div>
				</div>
			</div>

			<div class="bg-base-200 rounded-2xl p-8 border border-base-300">
				<h3 class="mb-4">Erreichbarkeit</h3>
				<div class="space-y-2 text-sm">
					{
						hours.map((h) => (
							<div class="flex justify-between">
								<span class="text-base-content/60">{h.days}</span>
								<span class="font-mono">{h.time}</span>
							</div>
						))
					}
				</div>
			</div>
		</div>
	</div>
</section>
