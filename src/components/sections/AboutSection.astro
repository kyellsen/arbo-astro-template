---
// src/components/sections/AboutSection.astro — About (reusable)
// Content is passed via props from the page, sourced from src/data/about.ts.
import type { AboutContent } from "../../data/about";
import SectionHeader from "../SectionHeader.astro";

interface Props extends AboutContent {}

const { headline, paragraphs, valuesHeadline, values } = Astro.props;
---

<!-- ═══════════════════════════════════════════════════
     Section 1: About the Organization
     ═══════════════════════════════════════════════════ -->
<section class="max-w-6xl mx-auto px-6 pt-24 pb-16 reveal-on-scroll">
	<SectionHeader headline={headline} />

	<div class="max-w-3xl">
		{paragraphs.map((p) => <p class="text-base-content/60 leading-relaxed mb-6">{p}</p>)}
	</div>
</section>

<!-- ═══════════════════════════════════════════════════
     Section 2: Our Principles
     ═══════════════════════════════════════════════════ -->
<section class="max-w-6xl mx-auto px-6 pt-16 pb-24">
	<h2 class="text-center mb-12">{valuesHeadline}</h2>

	<div class="grid md:grid-cols-3 gap-8">
		{
			values.map((value) => (
				<div class="apple-glass rounded-2xl p-8 text-center">
					<div
						class="w-14 h-14 rounded-xl flex items-center justify-center mx-auto mb-4"
						style={`background: oklch(from var(--color-${value.color}) l c h / 0.12); color: var(--color-${value.color});`}
					>
						<svg
							class="w-7 h-7"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
							aria-hidden="true"
							focusable="false"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d={value.iconPath}
							/>
						</svg>
					</div>
					<h3>{value.title}</h3>
					<p class="text-sm text-base-content/60 mt-2">{value.description}</p>
				</div>
			))
		}
	</div>
</section>
