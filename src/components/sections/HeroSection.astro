---
// src/components/sections/HeroSection.astro — Start-Hero (reusable)
// Content is passed via props from the page, sourced from src/data/hero.ts.
import type { HeroContent } from "../../data/hero";
import SectionHeader from "../SectionHeader.astro";
import { siteConfig } from "../../site.config";

interface Props extends HeroContent {}
const { badge, headline, highlightedText, description, ctas, features } = Astro.props;
---

<section class="max-w-6xl mx-auto px-6 py-24 reveal-on-scroll">
	<SectionHeader
		badge={badge}
		headline={headline}
		highlightedText={highlightedText}
		description={description}
		as="h1"
		align="center"
		marginBottom="mb-16"
	>
		<div class="mt-10 flex flex-wrap gap-4 justify-center">
			{
				ctas.map((cta) => (
					<a
						href={cta.href}
						class:list={[
							"btn btn-lg rounded-xl",
							cta.style === "primary" && "btn-primary shadow-lg",
							cta.style === "secondary" && "btn-secondary shadow-lg",
							cta.style === "accent" && "btn-accent shadow-lg",
							cta.style === "outline" && "btn-outline btn-primary",
							cta.style === "outline-secondary" && "btn-outline btn-secondary",
							cta.style === "outline-accent" && "btn-outline btn-accent",
						]}
					>
						{cta.label}
					</a>
				))
			}
		</div>
	</SectionHeader>

	<!-- Kurzvorstellung -->
	<div class="grid md:grid-cols-3 gap-8 mt-16">
		{
			features.map((feature) => (
				<div class="apple-glass rounded-2xl p-8 text-center">
					<div
						class:list={[
							"w-14 h-14 rounded-xl flex items-center justify-center mx-auto mb-4",
							`bg-${feature.color}/10 text-${feature.color}`,
						]}
					>
						<svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d={feature.iconPath}
							/>
						</svg>
					</div>
					<h3>{feature.title}</h3>
					<p class="text-sm text-base-content/60 mt-2">{feature.description}</p>
				</div>
			))
		}
	</div>

	<!-- Call To Action -->
	<div class="mt-16 flex justify-center">
		<a href={`tel:${siteConfig.contact.phone}`} class="btn btn-primary btn-lg rounded-xl shadow-lg">
			Jetzt telefonisch Besichtigungstermin vereinbaren
		</a>
	</div>
</section>
