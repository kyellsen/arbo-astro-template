---
// src/components/sections/ServicesSection.astro — Leistungen (reusable)
// Hero image exported for use in parallax start page
import heroImage from "../../assets/heroes/services-hero.png";
export const sectionMeta = {
	heroImage,
	heroAlt: "Baumpfleger bei der Kronenarbeit in einer alten Eiche",
};
---

<section class="max-w-6xl mx-auto px-6 py-24 animate-fade-in">
	<div class="mb-12">
		<span
			class="inline-block px-4 py-1 rounded-full bg-primary/10 border border-primary/20 text-primary text-xs font-mono font-bold tracking-widest uppercase mb-4"
		>
			Was wir tun
		</span>
		<h2>Unsere Leistungen</h2>
		<p class="text-base-content/70 mt-4 max-w-2xl">
			Von der fachgerechten Kronenpflege bis zur wissenschaftlichen Diagnostik – wir bieten das
			gesamte Spektrum rund um den Baum.
		</p>
	</div>

	<div class="grid md:grid-cols-2 gap-8">
		<!-- Leistung 1 -->
		<div
			class="bg-base-200 rounded-2xl p-8 border border-base-300 hover:border-primary/30 transition-all hover:-translate-y-1"
		>
			<div
				class="w-12 h-12 rounded-xl bg-primary/10 text-primary flex items-center justify-center mb-6"
			>
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"
					><path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"
					></path></svg
				>
			</div>
			<h3>Kronenpflege & Totholzentfernung</h3>
			<p class="text-base-content/60 mt-3 text-sm">
				Fachgerechte Baumpflege nach ZTV-Baumpflege per Seilklettertechnik (SKT).
				Lichtraumprofilschnitt, Einkürzungen und Kronenrestauration.
			</p>
		</div>

		<!-- Leistung 2 -->
		<div
			class="bg-base-200 rounded-2xl p-8 border border-base-300 hover:border-secondary/30 transition-all hover:-translate-y-1"
		>
			<div
				class="w-12 h-12 rounded-xl bg-secondary/10 text-secondary flex items-center justify-center mb-6"
			>
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"
					><path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"
					></path></svg
				>
			</div>
			<h3>Spezialfällung & Abtragung</h3>
			<p class="text-base-content/60 mt-3 text-sm">
				Sicheres Abtragen von Problembäumen mittels Rigging-Technik. Effizient, kontrolliert und mit
				minimalem Flurschaden.
			</p>
		</div>

		<!-- Leistung 3 -->
		<div
			class="bg-base-200 rounded-2xl p-8 border border-base-300 hover:border-accent/30 transition-all hover:-translate-y-1"
		>
			<div
				class="w-12 h-12 rounded-xl bg-accent/10 text-accent flex items-center justify-center mb-6"
			>
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"
					><path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
					></path></svg
				>
			</div>
			<h3>Baumkontrolle & Gutachten</h3>
			<p class="text-base-content/60 mt-3 text-sm">
				Visuelle Baumkontrolle (FLL), eingehende Untersuchung und Erstellung von
				Verkehrssicherheitsgutachten.
			</p>
		</div>

		<!-- Leistung 4 -->
		<div
			class="bg-base-200 rounded-2xl p-8 border border-base-300 hover:border-info/30 transition-all hover:-translate-y-1"
		>
			<div class="w-12 h-12 rounded-xl bg-info/10 text-info flex items-center justify-center mb-6">
				<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"
					><path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M3.055 11H5a2 2 0 012 2v1a2 2 0 002 2 2 2 0 012 2v2.945M8 3.935V5.5A2.5 2.5 0 0010.5 8h.5a2 2 0 012 2 2 2 0 104 0 2 2 0 012-2h1.064M15 20.488V18a2 2 0 012-2h3.064M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
					></path></svg
				>
			</div>
			<h3>Pflanzung & Standortberatung</h3>
			<p class="text-base-content/60 mt-3 text-sm">
				Auswahl geeigneter Baumarten, fachgerechte Pflanzung und langfristige Entwicklungspflege für
				Ihren Standort.
			</p>
		</div>
	</div>
</section>
