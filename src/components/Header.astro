---
// src/components/Header.astro
// Responsive Header with config-driven navigation, hamburger menu, and Dark/Light Mode Toggle.
// Navigation items, logo, and theme names are read from site.config.ts.
import { Image } from "astro:assets";
import { siteConfig } from "../site.config";
import logoSrc from "../assets/logo.webp";
import Icon from "./Icon.astro";

const { brand, theme, navigation } = siteConfig;

// Determine the current path for active link highlighting
const currentPath = Astro.url.pathname;

// Helper: check if a nav item matches the current page
function isActive(href: string): boolean {
	if (href === "/") return currentPath === "/";
	return currentPath.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-base-100/90 backdrop-blur-md border-b border-base-content/10">
	<div class="max-w-6xl mx-auto px-6 h-20 flex items-center justify-between">
		<!-- Logo / Wortmarke -->
		<a href="/" class="flex items-center gap-2">
			<Image
				src={logoSrc}
				alt={`${brand.name} Logo`}
				width={72}
				height={72}
				class="w-18 h-18 object-contain"
			/>
			<span class="font-bold text-xl tracking-tight">
				{brand.name}
				{brand.logoSubtitle && <span class="text-primary font-light">{brand.logoSubtitle}</span>}
			</span>
		</a>

		<!-- Desktop Navigation -->
		<nav class="hidden md:flex gap-8 font-medium text-base" aria-label="Hauptnavigation">
			{
				navigation.map((item) => {
					const active = isActive(item.href);
					return (
						<a
							href={item.href}
							class:list={["nav-link", { "nav-link--active": active }]}
							aria-current={active ? "page" : undefined}
							target={"external" in item && (item as any).external ? "_blank" : undefined}
							rel={"external" in item && (item as any).external ? "noopener" : undefined}
						>
							{item.label}
						</a>
					);
				})
			}
		</nav>

		<!-- Right: Theme Toggle + Hamburger -->
		<div class="flex items-center gap-2">
			<!-- Dark/Light Mode Toggle -->
			<button
				id="theme-toggle"
				class="btn btn-ghost btn-sm btn-circle"
				aria-label="Farbschema wechseln"
			>
				<!-- Sun icon (visible in dark mode) -->
				<Icon name="sun" id="icon-sun" class="hidden w-5 h-5" />
				<!-- Moon icon (visible in light mode) -->
				<Icon name="moon" id="icon-moon" class="w-5 h-5" />
			</button>

			<!-- Hamburger Button (mobile only) -->
			<button
				id="hamburger-btn"
				class="btn btn-ghost btn-sm btn-circle md:hidden"
				aria-label="Menü öffnen"
				aria-expanded="false"
				aria-controls="mobile-nav"
			>
				<Icon name="hamburger" class="hamburger-icon w-6 h-6" />
			</button>
		</div>
	</div>
</header>

<!-- Mobile Navigation Overlay -->
<div
	id="mobile-nav"
	class="mobile-nav-overlay"
	role="dialog"
	aria-modal="true"
	aria-label="Mobile Navigation"
>
	<div class="mobile-nav-panel apple-glass border-y-0 border-r-0 rounded-l-3xl">
		<!-- Close Button -->
		<div class="flex justify-end p-6">
			<button
				id="mobile-nav-close"
				class="btn btn-ghost btn-sm btn-circle"
				aria-label="Menü schließen"
			>
				<Icon name="close" class="w-6 h-6" />
			</button>
		</div>

		<!-- Mobile Nav Links -->
		<nav class="flex flex-col items-center gap-2 px-6 mt-8" aria-label="Mobile Navigation">
			{
				navigation.map((item) => {
					const active = isActive(item.href);
					return (
						<a
							href={item.href}
							class:list={["mobile-nav-link", { "mobile-nav-link--active": active }]}
							aria-current={active ? "page" : undefined}
							target={"external" in item && (item as any).external ? "_blank" : undefined}
							rel={"external" in item && (item as any).external ? "noopener" : undefined}
						>
							{item.label}
						</a>
					);
				})
			}
		</nav>

		<!-- Mobile Theme Toggle -->
		<div class="flex justify-center mt-12">
			<button
				id="theme-toggle-mobile"
				class="btn btn-ghost btn-sm gap-2"
				aria-label="Farbschema wechseln"
			>
				<Icon name="sun" id="icon-sun-mobile" class="hidden w-5 h-5" />
				<Icon name="moon" id="icon-moon-mobile" class="w-5 h-5" />
				<span class="text-sm">Theme wechseln</span>
			</button>
		</div>
	</div>
</div>

<script is:inline define:vars={{ themeLight: theme.light, themeDark: theme.dark }}>
	// Theme Toggle Logic — theme names from config
	function initHeader() {
		const toggleDesktop = document.getElementById("theme-toggle");
		const toggleMobile = document.getElementById("theme-toggle-mobile");
		const html = document.documentElement;
		const iconSun = document.getElementById("icon-sun");
		const iconMoon = document.getElementById("icon-moon");
		const iconSunMobile = document.getElementById("icon-sun-mobile");
		const iconMoonMobile = document.getElementById("icon-moon-mobile");

		function setTheme(theme) {
			html.setAttribute("data-theme", theme);
			localStorage.setItem("arbo-theme", theme);
			if (theme === themeDark) {
				iconSun.classList.remove("hidden");
				iconMoon.classList.add("hidden");
				if (iconSunMobile) iconSunMobile.classList.remove("hidden");
				if (iconMoonMobile) iconMoonMobile.classList.add("hidden");
			} else {
				iconSun.classList.add("hidden");
				iconMoon.classList.remove("hidden");
				if (iconSunMobile) iconSunMobile.classList.add("hidden");
				if (iconMoonMobile) iconMoonMobile.classList.remove("hidden");
			}
		}

		// Init: Check localStorage or system preference
		const savedTheme = localStorage.getItem("arbo-theme");
		if (savedTheme) {
			setTheme(savedTheme);
		} else if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
			setTheme(themeDark);
		}

		function toggleTheme() {
			const current = html.getAttribute("data-theme");
			setTheme(current === themeDark ? themeLight : themeDark);
		}

		toggleDesktop.addEventListener("click", toggleTheme);
		if (toggleMobile) toggleMobile.addEventListener("click", toggleTheme);

		// ── Mobile Navigation Logic ──
		const hamburgerBtn = document.getElementById("hamburger-btn");
		const mobileNav = document.getElementById("mobile-nav");
		const mobileNavClose = document.getElementById("mobile-nav-close");
		const mobileNavLinks = mobileNav.querySelectorAll(".mobile-nav-link");

		function openMobileNav() {
			mobileNav.classList.add("is-open");
			hamburgerBtn.setAttribute("aria-expanded", "true");
			hamburgerBtn.setAttribute("aria-label", "Menü schließen");
			hamburgerBtn.classList.add("is-active");
			document.body.classList.add("mobile-nav-body-lock");
		}

		function closeMobileNav() {
			mobileNav.classList.remove("is-open");
			hamburgerBtn.setAttribute("aria-expanded", "false");
			hamburgerBtn.setAttribute("aria-label", "Menü öffnen");
			hamburgerBtn.classList.remove("is-active");
			document.body.classList.remove("mobile-nav-body-lock");
		}

		hamburgerBtn.addEventListener("click", () => {
			const isOpen = mobileNav.classList.contains("is-open");
			isOpen ? closeMobileNav() : openMobileNav();
		});

		mobileNavClose.addEventListener("click", closeMobileNav);

		// Close on nav link click
		mobileNavLinks.forEach((link) => {
			link.addEventListener("click", closeMobileNav);
		});

		// Close on ESC
		document.addEventListener("keydown", (e) => {
			if (e.key === "Escape" && mobileNav.classList.contains("is-open")) {
				closeMobileNav();
			}
		});

		// Close on backdrop click
		mobileNav.addEventListener("click", (e) => {
			if (e.target === mobileNav) {
				closeMobileNav();
			}
		});
	}

	// Initialize on first load and after view transitions
	document.addEventListener("astro:page-load", initHeader);
</script>
