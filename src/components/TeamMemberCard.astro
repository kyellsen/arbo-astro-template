---
// src/components/TeamMemberCard.astro
// Reusable card component for team member profiles.
import { Image } from "astro:assets";

interface Props {
	name: string;
	role: string;
	description: string;
	imageSrc: ImageMetadata;
	imageAlt: string;
	color?: "primary" | "secondary" | "accent" | "info";
}

const { name, role, description, imageSrc, imageAlt, color = "primary" } = Astro.props;
---

<article
	class="group apple-glass rounded-2xl overflow-hidden transition-all duration-300 hover:shadow-xl hover:-translate-y-1"
>
	<!-- Portrait Image -->
	<div class="aspect-3/4 overflow-hidden">
		<Image
			src={imageSrc}
			alt={imageAlt}
			class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
			widths={[320, 480, 640]}
			sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 25vw"
		/>
	</div>

	<!-- Info -->
	<div class="p-6">
		<h3 class="text-lg mb-1">{name}</h3>
		<span
			class:list={[
				"inline-block px-3 py-0.5 rounded-full border text-xs font-mono font-semibold tracking-wide uppercase mb-3",
				`bg-${color}/10 border-${color}/20 text-${color}`,
			]}
		>
			{role}
		</span>
		<p class="text-sm text-base-content/60 leading-relaxed">{description}</p>
	</div>
</article>
