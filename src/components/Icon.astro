---
// src/components/Icon.astro
// Reusable Icon component for the common SVGs.
interface Props {
	name:
		| "sun"
		| "moon"
		| "hamburger"
		| "close"
		| "email"
		| "phone"
		| "whatsapp"
		| "signal"
		| "github"
		| "instagram"
		| "document"
		| "shield"
		| "location"
		| "clock";
	class?: string;
	id?: string;
}

const { name, class: className = "w-5 h-5", id } = Astro.props;

const isFilled = ["whatsapp", "signal", "github", "instagram"].includes(name);
const fill = isFilled ? "currentColor" : "none";
const stroke = !isFilled ? "currentColor" : "none";
const strokeWidth = !isFilled ? "2" : undefined;
const strokeLinecap = !isFilled ? "round" : undefined;
const strokeLinejoin = !isFilled ? "round" : undefined;
---

<svg
	class={className}
	id={id}
	viewBox="0 0 24 24"
	fill={fill}
	stroke={stroke}
	stroke-width={strokeWidth}
	stroke-linecap={strokeLinecap as any}
	stroke-linejoin={strokeLinejoin as any}
	aria-hidden="true"
	focusable="false"
>
	{
		name === "sun" && (
			<path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
		)
	}
	{
		name === "moon" && (
			<path d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
		)
	}
	{
		name === "hamburger" && (
			<>
				<line class="hamburger-line hamburger-line-1" x1="4" y1="6" x2="20" y2="6" />
				<line class="hamburger-line hamburger-line-2" x1="4" y1="12" x2="20" y2="12" />
				<line class="hamburger-line hamburger-line-3" x1="4" y1="18" x2="20" y2="18" />
			</>
		)
	}
	{name === "close" && <path d="M6 18L18 6M6 6l12 12" />}
	{
		name === "email" && (
			<path d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
		)
	}
	{
		name === "phone" && (
			<path d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
		)
	}
	{
		name === "whatsapp" && (
			<path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z" />
		)
	}
	{
		name === "signal" && (
			<path d="M12 0C5.373 0 0 5.373 0 12c0 6.627 5.373 12 12 12s12-5.373 12-12C24 5.373 18.627 0 12 0Zm-.005 5.513c3.55 0 6.438 2.89 6.438 6.439 0 3.55-2.889 6.44-6.438 6.44-1.229 0-2.384-.343-3.37-.938l-4.14 1.353 1.378-4.004a6.406 6.406 0 0 1-.951-3.328c0-3.55 2.888-6.44 6.437-6.44Z" />
