---
// src/components/ProjectGalleryCard.astro
// Image card for the project detail gallery.
import { Image } from "astro:assets";

interface Props {
	src: ImageMetadata;
	alt: string;
}

const { src, alt } = Astro.props;
---

<figure
	class="group bg-base-200 rounded-2xl border border-base-300 overflow-hidden transition-all duration-300 hover:shadow-xl"
>
	<div class="overflow-hidden">
		<Image
			src={src}
			alt={alt}
			class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
			widths={[400, 640, 800, 1024]}
			sizes="(max-width: 640px) 100vw, (max-width: 1024px) 50vw, 33vw"
		/>
	</div>
</figure>
