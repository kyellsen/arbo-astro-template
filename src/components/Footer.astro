---
// src/components/Footer.astro
// Two-column footer with contact info, social links, and legal links.
// On mobile, everything stacks vertically.
// All contact data is sourced from site.config.ts (Single Source of Truth).
import { siteConfig } from "../site.config";
import Icon from "./Icon.astro";

const { company, contact, social } = siteConfig;
---

<footer class="bg-base-200 border-t border-base-300 mt-16">
	<!-- Main area: two columns on desktop, single on mobile -->
	<div class="max-w-6xl mx-auto px-4 py-8 sm:px-6 sm:py-12">
		<div class="grid grid-cols-1 gap-8 md:grid-cols-2 md:gap-12">
			<!-- Contact Info -->
			<div class="text-center md:text-left">
				<h2 class="text-base font-bold uppercase tracking-widest text-base-content/50 mb-3">
					Contact
				</h2>
				<div class="space-y-1 text-base text-base-content/70">
					<p class="font-semibold text-base-content">{company.name}</p>
					<p class="text-base-content/60">Developed by {company.owner}</p>
				</div>
				<div class="mt-4 space-y-2 text-base inline-flex flex-col items-center md:items-start">
					<a
						href={`mailto:${contact.email}`}
						class="flex items-center gap-2 hover:text-primary transition-colors"
					>
						<Icon name="email" class="w-4 h-4 shrink-0" />
						<span class="font-mono break-all">{contact.email}</span>
					</a>
				</div>
			</div>

			<!-- Social & Legal -->
			<div class="flex flex-col gap-8 text-center md:text-left">
				<!-- Social & Partner Links -->
				<div>
					<h2 class="text-base font-bold uppercase tracking-widest text-base-content/50 mb-3">
						Social & Open Source
					</h2>
					<div class="inline-flex flex-col gap-2 text-base items-center md:items-start">
						<a
							href={social.github}
							target="_blank"
							rel="noopener"
							class="flex items-center gap-2 hover:text-primary transition-colors"
							aria-label="GitHub"
						>
							<Icon name="github" class="w-4 h-4 shrink-0" />
							<span>GitHub</span>
						</a>
					</div>
				</div>

				<!-- Legal Navigation -->
				<div>
					<h2 class="text-base font-bold uppercase tracking-widest text-base-content/50 mb-3">
						Legal
					</h2>
					<div class="inline-flex flex-col gap-2 text-base items-center md:items-start">
						<a
							href="/impressum"
							class="flex items-center gap-2 hover:text-primary transition-colors"
						>
							<Icon name="document" class="w-4 h-4 shrink-0" />
							<span>Legal Notice</span>
						</a>
						<a
							href="/datenschutz"
							class="flex items-center gap-2 hover:text-primary transition-colors"
						>
							<Icon name="shield" class="w-4 h-4 shrink-0" />
							<span>Privacy Policy</span>
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Copyright line -->
	<div class="border-t border-base-300 py-4 px-4 sm:py-6 sm:px-6">
		<div class="max-w-6xl mx-auto text-center text-sm text-base-content/50">
			&copy; {new Date().getFullYear()}
			{company.name} · {company.owner}. All rights reserved.
		</div>
	</div>
</footer>
