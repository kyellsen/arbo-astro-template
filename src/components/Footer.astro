---
// src/components/Footer.astro
// Zweispaltiger Footer mit Kontaktdaten, Social Links und rechtlichen Links.
// Auf Mobilgeräten wird alles untereinander (einspaltig) dargestellt.
// Alle Kontaktdaten stammen aus site.config.ts (Single Source of Truth).
import { siteConfig } from "../site.config";

const { company, contact, social } = siteConfig;
const addr = company.address;
---

<footer class="bg-base-200 border-t border-base-300 mt-16">
	<!-- Hauptbereich: Auf Desktop zweispaltig, auf Mobil einspaltig -->
	<div class="max-w-6xl mx-auto px-4 py-8 sm:px-6 sm:py-12">
		<div class="grid grid-cols-1 gap-8 md:grid-cols-2 md:gap-12">
			<!-- Kontaktdaten -->
			<div class="text-center md:text-left">
				<h4 class="text-base font-bold uppercase tracking-widest text-base-content/50 mb-3">
					Kontakt
				</h4>
				<div class="space-y-1 text-base text-base-content/70">
					<p class="font-semibold text-base-content">{company.name}</p>
					<p class="font-medium text-base-content">Inhaber: {company.owner}</p>
					<p>{addr.street}</p>
					<p>{addr.zip} {addr.city}</p>
				</div>
				<div class="mt-4 space-y-2 text-base inline-flex flex-col items-center md:items-start">
					<a
						href={`mailto:${contact.email}`}
						class="flex items-center gap-2 hover:text-primary transition-colors"
					>
						<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"
							><path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
							></path>
						</svg>
						<span class="font-mono break-all">{contact.email}</span>
					</a>
					<a
						href={`tel:${contact.phone}`}
						class="flex items-center gap-2 hover:text-primary transition-colors"
					>
						<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"
							><path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
							></path>
						</svg>
						<span class="font-mono">{contact.phoneDisplay}</span>
					</a>
					<a
						href={contact.whatsapp}
						target="_blank"
						rel="noopener"
						class="flex items-center gap-2 hover:text-primary transition-colors"
					>
						<svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24"
							><path
								d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"
							></path>
						</svg>
						<span>Per WhatsApp schreiben</span>
					</a>
					<a
						href={contact.signal}
						target="_blank"
						rel="noopener"
						class="flex items-center gap-2 hover:text-primary transition-colors"
					>
						<svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24"
							><path
								d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 15l-4-4 1.41-1.41L11 14.17l6.59-6.59L19 9l-8 8z"
							></path>
						</svg>
						<span>Per Signal schreiben</span>
					</a>
				</div>
			</div>

			<!-- Social & Partner + Rechtliches -->
			<div class="flex flex-col gap-8 text-center md:text-left">
				<!-- Social & Partner Links -->
				<div>
					<h4 class="text-base font-bold uppercase tracking-widest text-base-content/50 mb-3">
						Social & Partner
					</h4>
					<div class="inline-flex flex-col gap-2 text-base items-center md:items-start">
						<a
							href={social.github}
							target="_blank"
							rel="noopener"
							class="flex items-center gap-2 hover:text-primary transition-colors"
							aria-label="GitHub"
						>
							<svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24"
								><path
									fill-rule="evenodd"
									d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z"
									clip-rule="evenodd"></path>
							</svg>
							<span>GitHub</span>
						</a>
						<a
							href={social.instagram}
							target="_blank"
							rel="noopener"
							class="flex items-center gap-2 hover:text-primary transition-colors"
							aria-label="Instagram"
						>
							<svg class="w-4 h-4 shrink-0" fill="currentColor" viewBox="0 0 24 24"
								><path
									d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"
								></path>
							</svg>
							<span>Instagram</span>
						</a>
					</div>
				</div>

				<!-- Rechtliche Navigation -->
				<div>
					<h4 class="text-base font-bold uppercase tracking-widest text-base-content/50 mb-3">
						Rechtliches
					</h4>
					<div class="inline-flex flex-col gap-2 text-base items-center md:items-start">
						<a href="/contact" class="flex items-center gap-2 hover:text-primary transition-colors">
							<!-- Briefumschlag-Icon -->
							<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"
								><path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
								></path>
							</svg>
							<span>Kontakt</span>
						</a>
						<a
							href="/impressum"
							class="flex items-center gap-2 hover:text-primary transition-colors"
						>
							<!-- Dokument-Icon -->
							<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"
								><path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
								></path>
							</svg>
							<span>Impressum</span>
						</a>
						<a
							href="/datenschutz"
							class="flex items-center gap-2 hover:text-primary transition-colors"
						>
							<!-- Schild/Datenschutz-Icon -->
							<svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"
								><path
									stroke-linecap="round"
									stroke-linejoin="round"
									stroke-width="2"
									d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"
								></path>
							</svg>
							<span>Datenschutz</span>
						</a>
					</div>
				</div>
			</div>
		</div>
	</div>

	<!-- Copyright-Zeile ganz unten -->
	<div class="border-t border-base-300 py-4 px-4 sm:py-6 sm:px-6">
		<div class="max-w-6xl mx-auto text-center text-sm text-base-content/50">
			&copy; {new Date().getFullYear()}
			{company.owner}. Alle Rechte vorbehalten.
		</div>
	</div>
</footer>
