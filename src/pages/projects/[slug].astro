---
// src/pages/projects/[slug].astro — Project detail page
import Layout from "../../layouts/Layout.astro";
import ProjectGalleryCard from "../../components/ProjectGalleryCard.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
	const projects = await getCollection("projects");
	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { title, description, date, tags, gallery, color, github } = project.data;
const { Content } = await render(project);
const colorVar = color ? `var(--color-${color})` : "var(--color-primary)";

const formattedDate = date.toLocaleDateString("en-US", {
	year: "numeric",
	month: "long",
	day: "numeric",
});
---

<Layout title={title}>
	<section class="py-20 px-6">
		<div class="max-w-6xl mx-auto">
			<!-- Back Link -->
			<a
				href="/projects"
				class="inline-flex items-center gap-2 text-sm text-base-content/50 hover:text-primary transition-colors mb-10 font-mono"
			>
				<svg
					class="w-4 h-4"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
					aria-hidden="true"
					focusable="false"
				>
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"
					></path>
				</svg>
				All Projects
			</a>

			<!-- Project Header -->
			<div class="mb-12 reveal-on-scroll">
				<h1 class="mb-4">{title}</h1>
				<p class="text-lg text-base-content/60 leading-relaxed max-w-3xl mb-6">
					{description}
				</p>

				<div class="flex flex-wrap items-center gap-4">
					<!-- Tags -->
					<div class="flex flex-wrap gap-2">
						{
							tags.map((tag) => (
								<span
									class="badge badge-outline badge-sm font-mono"
									style={`color: ${colorVar}; border-color: oklch(from ${colorVar} l c h / 0.3);`}
								>
									{tag}
								</span>
							))
						}
					</div>

					<!-- Separator -->
					<span class="hidden sm:inline text-base-content/20">|</span>

					<!-- Date -->
					<div
						class="flex items-center gap-2 text-sm font-mono"
						style={`color: oklch(from ${colorVar} l c h / 0.7);`}
					>
						<svg
							class="w-4 h-4"
							fill="none"
							stroke="currentColor"
							viewBox="0 0 24 24"
							aria-hidden="true"
							focusable="false"
						>
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
							></path>
						</svg>
						<time datetime={date.toISOString().split("T")[0]}>
							{formattedDate}
						</time>
					</div>
				</div>
			</div>

			<!-- Markdown Body Content -->
			<div class="prose prose-lg max-w-3xl mb-16">
				<Content />
			</div>

			<!-- GitHub CTA -->
			{
				github && (
					<div class="flex justify-center mb-16">
						<a
							href={github}
							target="_blank"
							rel="noopener noreferrer"
							class="btn btn-lg rounded-xl shadow-lg gap-3 text-lg px-10"
							style={`background-color: ${colorVar}; color: oklch(18% 0.02 0); border: none;`}
						>
							<svg
								class="w-6 h-6"
								fill="currentColor"
								viewBox="0 0 24 24"
								aria-hidden="true"
								focusable="false"
							>
								<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
							</svg>
							View on GitHub
						</a>
					</div>
				)
			}

			<!-- Gallery (only if images exist) -->
			{
				gallery && gallery.length > 0 && (
					<div class="mb-8">
						<h2 class="mb-8">Gallery</h2>
						<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
							{gallery.map((image, index) => (
								<ProjectGalleryCard src={image} alt={`${title} — Image ${index + 1}`} />
							))}
						</div>
					</div>
				)
			}

			<!-- Back to overview -->
			<div class="mt-16 pt-8 border-t border-base-300">
				<a
					href="/projects"
					class="inline-flex items-center gap-2 text-sm text-base-content/50 hover:text-primary transition-colors font-mono"
				>
					<svg
						class="w-4 h-4"
						fill="none"
						stroke="currentColor"
						viewBox="0 0 24 24"
						aria-hidden="true"
						focusable="false"
					>
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M15 19l-7-7 7-7"></path>
					</svg>
					Back to Projects
				</a>
			</div>
		</div>
	</section>
</Layout>
