---
// src/pages/projects/[slug].astro — Project detail page with gallery
import Layout from "../../layouts/Layout.astro";
import ProjectGalleryCard from "../../components/ProjectGalleryCard.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
	const projects = await getCollection("projects");
	return projects.map((project) => ({
		params: { slug: project.id },
		props: { project },
	}));
}

const { project } = Astro.props;
const { title, description, date, tags, gallery } = project.data;
const { Content } = await render(project);

const formattedDate = date.toLocaleDateString("de-DE", {
	year: "numeric",
	month: "long",
	day: "numeric",
});
---

<Layout title={title}>
	<section class="py-20 px-6">
		<div class="max-w-6xl mx-auto">
			<!-- Back Link -->
			<a
				href="/projects"
				class="inline-flex items-center gap-2 text-sm text-base-content/50 hover:text-primary transition-colors mb-10 font-mono"
			>
				<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
					<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"
					></path>
				</svg>
				Alle Projekte
			</a>

			<!-- Project Header -->
			<div class="mb-12 animate-fade-in">
				<h1 class="mb-4">{title}</h1>
				<p class="text-lg text-base-content/60 leading-relaxed max-w-3xl mb-6">
					{description}
				</p>

				<div class="flex flex-wrap items-center gap-4">
					<!-- Tags -->
					<div class="flex flex-wrap gap-2">
						{tags.map((tag) => <span class="badge badge-outline badge-sm font-mono">{tag}</span>)}
					</div>

					<!-- Separator -->
					<span class="hidden sm:inline text-base-content/20">|</span>

					<!-- Date -->
					<div class="flex items-center gap-2 text-sm text-base-content/40 font-mono">
						<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
							<path
								stroke-linecap="round"
								stroke-linejoin="round"
								stroke-width="2"
								d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"
							></path>
						</svg>
						<time datetime={date.toISOString().split("T")[0]}>
							{formattedDate}
						</time>
					</div>
				</div>
			</div>

			<!-- Markdown Body Content -->
			<div class="prose prose-lg max-w-3xl mb-16">
				<Content />
			</div>

			<!-- Gallery -->
			<div class="mb-8">
				<h2 class="mb-8">Fotogalerie</h2>
				<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
					{
						gallery.map((image, index) => (
							<ProjectGalleryCard src={image} alt={`${title} — Bild ${index + 1}`} />
						))
					}
				</div>
			</div>

			<!-- Back to overview -->
			<div class="mt-16 pt-8 border-t border-base-300">
				<a
					href="/projects"
					class="inline-flex items-center gap-2 text-sm text-base-content/50 hover:text-primary transition-colors font-mono"
				>
					<svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
						<path
							stroke-linecap="round"
							stroke-linejoin="round"
							stroke-width="2"
							d="M15 19l-7-7 7-7"></path>
					</svg>
					Zurück zur Übersicht
				</a>
			</div>
		</div>
	</section>
</Layout>
