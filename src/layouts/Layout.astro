---
// src/layouts/Layout.astro
import { ClientRouter } from "astro:transitions";
import "@fontsource-variable/geist";
import "@fontsource-variable/geist-mono";
import "../styles/global.css";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SEOHead from "../components/SEOHead.astro";
import { siteConfig } from "../site.config";

interface Props {
	/** Seitentitel (wird ins titleTemplate eingesetzt) */
	title?: string;
	/** Meta-Description — überschreibt den Default aus seo.ts */
	description?: string;
	/** OG-Image — überschreibt den Default aus seo.ts */
	ogImage?: string;
	/** Canonical URL — default: automatisch aus Pfad */
	canonicalUrl?: string;
	/** Seite nicht indexieren? */
	noindex?: boolean;
}

const { title, description, ogImage, canonicalUrl, noindex } = Astro.props;
---

<!doctype html>
<html lang={siteConfig.lang} data-theme={siteConfig.theme.light}>
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<ClientRouter />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<link rel="icon" type="image/webp" href="/favicon.webp" />
		<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
		<SEOHead
			title={title}
			description={description}
			ogImage={ogImage}
			canonicalUrl={canonicalUrl}
			noindex={noindex}
		/>
	</head>
	<body class="body-gradient min-h-screen flex flex-col font-sans text-base-content antialiased">
		<a
			href="#main-content"
			class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-100 btn btn-primary"
		>
			Zum Hauptinhalt springen
		</a>
		<Header />
		<main id="main-content" class="grow">
			<slot />
		</main>
		<Footer />
		<script>
			// Scroll-Reveal Logic (Astro View Transitions compatible)
			function initScrollReveal() {
				const observerOptions = {
					root: null,
					rootMargin: "0px",
					threshold: 0.1,
				};

				const observer = new IntersectionObserver((entries, observer) => {
					entries.forEach((entry) => {
						if (entry.isIntersecting) {
							entry.target.classList.add("is-visible");
							observer.unobserve(entry.target);
						}
					});
				}, observerOptions);

				const revealElements = document.querySelectorAll(".reveal-on-scroll");
				revealElements.forEach((el) => observer.observe(el));
			}

			// Run on initial load and after view transitions
			document.addEventListener("astro:page-load", initScrollReveal);
		</script>
	</body>
</html>
